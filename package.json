{
  "name": "hms-pro-desktop",
  "version": "1.0.7",
  "description": "Hospital Management System Desktop Application",
  "author": "HMS Team",
  "main": "electron/main.js",
  "scripts": {
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:electron": "wait-on http://localhost:3000 && set SKIP_BACKEND=1 && electron .",
    "dev": "concurrently -n \"BACKEND,FRONTEND,ELECTRON\" -c \"blue,green,yellow\" \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:electron\"",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.hmspro.app",
    "productName": "HMS Pro",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!test"
        ]
      }
    ],
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "axios": "^1.13.2",
    "lucide-react": "^0.562.0",
    "react-router-dom": "^7.12.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.2.1",
    "electron-builder": "^26.4.0",
    "wait-on": "^7.2.0"
  }
}